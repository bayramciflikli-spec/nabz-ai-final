# Firebase – .env.local oluşturup bu değerleri doldurun.
# Firebase Console: https://console.firebase.google.com → Proje ayarları → Genel

# Site URL – Sitemap ve robots.txt için (örn: https://nabz.app)
NEXT_PUBLIC_APP_URL=https://nabz-ai.com

# === GİRİŞ (Google vb.) İÇİN ZORUNLU – Eksik/yanlış olursa "argument-error" alırsınız ===
# Tüm değerleri Firebase Console → Proje Ayarları (dişli) → Genel → "Web uygulamanız" / SDK kurulumundan kopyalayın.
# authDomain MUTLAKA şu formatta olmalı: PROJE_ID.firebaseapp.com (başında https:// YOK, sonunda / YOK)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBJm7MzkQ3E34YS-JamV1WwgI_ZE9J8Xic
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=benim-ai-projem-2.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=benim-ai-projem-2
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=benim-ai-projem-2.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1038696681950
NEXT_PUBLIC_FIREBASE_APP_ID=1:1038696681950:web:2ff887748bb0a688898d4f
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-13NL4QB3VT

# Auth Emulator - true: Giriş Console olmadan çalışır (firebase emulators:start --only auth)
NEXT_PUBLIC_USE_AUTH_EMULATOR=false

# OpenAI – DALL-E 3 için (Banner üretimi)
OPENAI_API_KEY=

# Google AdSense – Reklam geliri (Monetizasyon)
# https://www.google.com/adsense/ adresinden başvuru yapın
# Onay sonrası ca-pub-xxxxxxxxxx formatında client ID alın
# ÖNEMLİ: AdSense panelinde /yasal/reklam-politikasi'ndaki yasaklı kategorileri engelleyin
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Opsiyonel: Ülkeye göre farklı reklam birimleri (AdSense panelinde bölgesel birimler oluşturun)
# NEXT_PUBLIC_ADSENSE_SLOT_TR=   # Türkiye
# NEXT_PUBLIC_ADSENSE_SLOT_DE=   # Almanya, Avusturya, İsviçre
# NEXT_PUBLIC_ADSENSE_SLOT_US=   # ABD
# NEXT_PUBLIC_ADSENSE_SLOT_GB=   # İngiltere
# NEXT_PUBLIC_ADSENSE_SLOT_FR=   # Fransa
# NEXT_PUBLIC_ADSENSE_SLOT_ES=   # İspanya, Meksika
# NEXT_PUBLIC_ADSENSE_SLOT_BR=   # Brezilya
# NEXT_PUBLIC_ADSENSE_SLOT_IN=   # Hindistan
# NEXT_PUBLIC_ADSENSE_SLOT_JP=   # Japonya
# NEXT_PUBLIC_ADSENSE_SLOT_KR=   # Güney Kore
# NEXT_PUBLIC_ADSENSE_SLOT_ZH=   # Çin, Tayvan

# Firebase Admin – Kalıcı Storage için (Banner kaydetme)
# Firebase Console > Proje Ayarları > Hizmet Hesapları > Yeni özel anahtar oluştur
# Oluşan JSON dosyasının tüm içeriğini tek satır olarak buraya yapıştırın
FIREBASE_SERVICE_ACCOUNT_KEY=

# Admin Panel + Ekosistem sahibi (tek yetkili: bayramciflikli@gmail.com)
# Kodda bu UID zaten tanımlı; Vercel'de boş bırakırsanız yine tek yetkili geçerli olur.
NEXT_PUBLIC_ADMIN_UIDS=iZt8LY8jfpeGwCqxNU0HjhHCoIq2

# Opsiyonel: Kurucu e-posta (bypass bilgi bandında gösterilir)
# NEXT_PUBLIC_ADMIN_EMAIL=bayramciflikli@gmail.com

# Kurucu (super_admin) – Şeffaflık raporu yayınlama yetkisi
# Virgülle ayrılmış UID listesi. Boşsa Firestore users/{uid}.role == 'super_admin' kontrol edilir.
NEXT_PUBLIC_SUPER_ADMIN_UIDS=

# Master Key – Overdrive modu (root yetkisiyle rapor yükleme)
# Sunucu izinleri manuel resetlendiğinde kullanın. Gizli tutun.
NABZ_MASTER_KEY=

# NABZ-AI Harici API + Flask (Python scriptleri / nabz_local_server.py)
# NABZ_API_KEY=buraya_anahtarini_yapistir
# PORT=5050
# DEBUG=False
# MASTER_KEY=nabz_core_anahtari   # POST /nabz-core için X-API-KEY header (veya NABZ_MASTER_KEY)
# NABZ_LICENSE_KEY=               # MASTER-LOCK / MasterHub (mühendislere verme)
# NABZ_ALLOWED_USERS=Kaptan,Admin # MasterHub: VERIFY_SUBSCRIPTION için yetkili kullanıcılar
#
# İsteğe bağlı: NABZ_LOCAL_HOST=127.0.0.1 (sadece bu PC; varsayılan 0.0.0.0)
# NABZ_API_URL=https://api.nabz-ai.com/v1/process

# Yasal iletişim – KVKK, DMCA, gizlilik talepleri için e-posta (varsayılan: legal@nabz.app)
NEXT_PUBLIC_LEGAL_EMAIL=legal@nabz-ai.com

# E-posta bildirimleri (Resend)
# https://resend.com üzerinden API key alın
RESEND_API_KEY=
# Bildirimlerin gideceği e-posta (admin bildirimleri + DMCA formu)
ADMIN_EMAIL=
# Gönderen adresi (Resend doğrulanmış domain gerekir; yoksa onboarding@resend.dev)
# RESEND_FROM=NABZ AI <bildirim@nabz.app>

# Vercel Cron için (opsiyonel - otomatik bildirim)
CRON_SECRET=

# Telif kontrolü (check-copyright API)
# TinEye – Görsel reverse search: https://services.tineye.com/
TINEYE_API_KEY=
# ACRCloud – Ses/video tanıma: https://www.acrcloud.com/ → Console'dan host, access_key, access_secret alın
ACR_CLOUD_HOST=
ACR_CLOUD_ACCESS_KEY=
ACR_CLOUD_ACCESS_SECRET=
